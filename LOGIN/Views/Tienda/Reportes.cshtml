@{
    ViewData["Title"] = "Reportes del Día";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: #1c2541 !important;">
        <h1 class="text-primary mb-0">
            <i class="bi bi-file-earmark-bar-graph me-2"></i>Reporte de Ventas del Día
        </h1>
        <span class="badge bg-dark border border-info p-2 fs-6 text-info">
            <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd/MM/yyyy")
        </span>
    </div>
    
    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <div class="card producto-card p-4 text-center" style="background-color: #0b132b !important; border: 1px solid #1c2541 !important;">
                <i class="bi bi-cash-coin fs-1 text-primary mb-2"></i>
                <h5 class="card-title text-muted">Total Ganado Hoy</h5>
                <p class="fs-2 fw-bold product-price" style="color: #00f0ff !important;">Bs. 0.00</p>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card producto-card p-4 text-center" style="background-color: #0b132b !important; border: 1px solid #1c2541 !important;">
                <i class="bi bi-box-seam fs-1 text-info mb-2"></i>
                <h5 class="card-title text-muted">Productos Vendidos Hoy</h5>
                <p class="fs-2 fw-bold text-info">0 Unidades</p>
            </div>
        </div>
    </div>

    <div class="card producto-card p-4" style="background-color: #0b132b !important; border: 1px solid #1c2541 !important;">
        <h3 class="text-white mb-4"><i class="bi bi-list-stars text-primary me-2"></i>Productos Vendidos Hoy</h3>
        
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle border-0">
                <thead>
                    <tr style="border-bottom: 2px solid #00f0ff !important;">
                        <th class="text-primary py-3">Imagen</th>
                        <th class="text-primary py-3">Producto</th>
                        <th class="text-primary py-3 text-center">Cantidad</th>
                        <th class="text-primary py-3 text-end">Precio Unitario</th>
                        <th class="text-primary py-3 text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-bottom" style="border-color: #1c2541 !important;">
                        <td>
                            <div class="bg-light rounded d-inline-block" style="width: 50px; height: 50px; background-color: #0a1128 !important;"></div>
                        </td>
                        <td class="fw-bold text-white">Producto de Muestra</td>
                        <td class="text-center">0</td>
                        <td class="text-end">Bs. 0.00</td>
                        <td class="text-end fw-bold" style="color: #00f0ff !important;">Bs. 0.00</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>