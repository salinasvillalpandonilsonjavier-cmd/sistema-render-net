@model IEnumerable<LOGIN.Models.Producto>
@{
    ViewData["Title"] = "AdoMarket - Catálogo";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="display-5 fw-bold text-white mb-0">
            <i class="bi bi-shop me-2" style="color: #00f0ff !important;"></i>Catálogo
        </h1>
        <p class="text-muted mt-2">Encuentra los mejores productos al mejor precio.</p>
    </div>
    <a asp-action="Carrito" class="btn btn-primary rounded-pill px-4 py-2 position-relative shadow-sm" style="background-color: #007bff !important; border-color: #0056b3 !important;">
        <i class="bi bi-cart3 fs-5"></i>
        <span id=\"cart-badge\" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: @(ViewBag.CarritoCount > 0 ? "block" : "none");">
            @ViewBag.CarritoCount
        </span>
        <span class="ms-2 fw-semibold">Mi Carrito</span>
    </a>
</div>

<div class="row g-4">
    @foreach (var producto in Model)
    {
        <div class="col-md-6 col-lg-4 col-xl-3">
            <div class="card producto-card h-100 border-0">
                <div class="card-img-top text-center py-4 position-relative" style="background-color: #0a1128 !important; min-height: 160px; display: flex; align-items: center; justify-content: center;">
                    @if (producto.Cantidad < 5 && producto.Cantidad > 0)
                    {
                        <span class="position-absolute top-0 start-0 m-3 badge bg-warning text-dark" style="z-index: 10;">¡Últimas @producto.Cantidad!</span>
                    }
                    
                    @if (!string.IsNullOrEmpty(producto.ImagenUrl))
                    {
                        <img src="@producto.ImagenUrl" alt="@producto.Nombre" style="max-height: 130px; max-width: 85%; object-fit: contain;" />
                    }
                    else
                    {
                        <i class="bi bi-box-seam text-muted opacity-50" style="font-size: 5rem; color: #00f0ff !important;"></i>
                    }
                </div>
                
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold text-white mb-1">@producto.Nombre</h5>
                    <p class="card-text text-muted small flex-grow-1 mt-2">
                        @(producto.Descripcion?.Length > 60 ? producto.Descripcion.Substring(0, 60) + "..." : producto.Descripcion ?? "Sin descripción")
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                        <span class="fs-4 fw-bold" style="color: #00f0ff !important;">Bs @producto.Precio.ToString("F2")</span>
                        
                        @if (producto.Cantidad > 0)
                        {
                            <button class="btn btn-sm btn-gradient add-to-cart" data-id="@producto.Id">
                                <i class="bi bi-cart-plus me-1"></i>Agregar
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-light text-danger fw-bold" disabled>Agotado</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* 1. Fondo de la Tienda usando la paleta AdoMarket */
    body, html, main, .container-fluid, .container {
        background-color: #050811 !important;
        background: radial-gradient(circle at top, #0a1128 0%, #050811 100%) !important;
        color: #ffffff !important;
    }

    /* 2. Tarjetas en Azul Marino Profundo */
    .producto-card {
        background-color: #0b132b !important;
        border: 1px solid #1c2541 !important;
        border-radius: 1rem;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

    /* Contenedor de la foto en gris oscuro/marino */
    .card-img-top {
        background-color: #0a1128 !important;
    }

    /* 3. Efecto Hover con brillo Azul Eléctrico Neón */
    .producto-card:hover {
        transform: translateY(-8px);
        border-color: #00f0ff !important;
        box-shadow: 0 0 20px rgba(0, 240, 255, 0.4) !important;
    }

    /* Línea divisoria interna */
    .border-top {
        border-top: 1px solid #1c2541 !important;
    }

    /* 4. Botón de Agregar estilo Azul Eléctrico */
    .btn-gradient, .add-to-cart {
        background-color: #007bff !important;
        background-image: none !important;
        color: #ffffff !important;
        border: 1px solid #0056b3 !important;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .btn-gradient:hover, .add-to-cart:hover {
        background-color: #00f0ff !important;
        border-color: #00f0ff !important;
        color: #050811 !important;
        box-shadow: 0 0 10px #00f0ff;
    }

    /* 5. Estilo de los Toasts de SweetAlert con borde Neón */
    .swal2-popup.swal2-toast {
        background-color: #0b132b !important;
        color: #ffffff !important;
        border: 1px solid #00f0ff !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            const Toast = Swal.mixin({
                toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, timerProgressBar: true
            });

            $('.add-to-cart').click(function() {
                var btn = $(this);
                var productoId = btn.data('id');

                var iconOriginal = btn.html();
                btn.html('<span class="spinner-border spinner-border-sm"></span>');

                $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
                    .done(function(response) {
                        btn.html(iconOriginal);
                        if (response.success) {
                            if (response.count > 0) {
                                $('#cart-badge').text(response.count).show();
                            }
                            Toast.fire({ icon: 'success', title: 'Agregado al carrito' });
                        } else {
                            Toast.fire({ icon: 'error', title: response.message });
                        }
                    })
                    .fail(function() {
                        btn.html(iconOriginal);
                        Toast.fire({ icon: 'error', title: 'Error de conexión' });
                    });
            });
        });
    </script>
}