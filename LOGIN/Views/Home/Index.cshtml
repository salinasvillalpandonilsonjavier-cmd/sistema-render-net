@{
    ViewData["Title"] = "Panel de Control";
}

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-12">
            <div class="card card-modern border-0 overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body p-5 text-center text-md-start d-md-flex align-items-center justify-content-between">
                    <div class="text-white">
                        <h2 class="fw-bold mb-2 display-6">¡Hola, @ViewBag.NombreUsuario! 👋</h2>
                        <p class="fs-5 mb-0 opacity-75">Bienvenido a tu panel de control principal.</p>
                    </div>
                    <div class="mt-4 mt-md-0">
                        <a asp-controller="Tienda" asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-bold text-primary px-4 shadow-sm">
                            <i class="bi bi-shop me-2"></i>Ir de Compras
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-4 text-dark"><i class="bi bi-grid-1x2 text-primary me-2"></i>Accesos Rápidos</h4>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card card-modern h-100 border-0 text-center p-4">
                <div class="card-body d-flex flex-column">
                    <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-box-seam fs-1 text-info"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Inventario</h4>
                    <p class="text-muted small flex-grow-1">Gestiona los productos, agrega nuevo stock, actualiza precios y descripciones.</p>
                    <a asp-controller="ProductosView" asp-action="Index" class="btn btn-outline-info rounded-pill w-100 mt-3 fw-semibold">
                        Administrar <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-modern h-100 border-0 text-center p-4">
                <div class="card-body d-flex flex-column">
                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-cart3 fs-1 text-success"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Tienda Virtual</h4>
                    <p class="text-muted small flex-grow-1">Explora el catálogo público, agrega productos al carrito y realiza compras simuladas.</p>
                    <a asp-controller="Tienda" asp-action="Index" class="btn btn-outline-success rounded-pill w-100 mt-3 fw-semibold">
                        Visitar Tienda <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-modern h-100 border-0 text-center p-4">
                <div class="card-body d-flex flex-column">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-bag-check fs-1 text-warning"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Mis Pedidos</h4>
                    <p class="text-muted small flex-grow-1">Revisa el historial de tus compras, facturas y el estado de tus pedidos recientes.</p>
                    <a asp-controller="Tienda" asp-action="MisCompras" class="btn btn-outline-warning rounded-pill w-100 mt-3 fw-semibold text-dark">
                        Ver Historial <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-modern:hover .bg-opacity-10 {
        transform: scale(1.1);
        transition: transform 0.3s ease;
    }

    .bg-opacity-10 {
        transition: transform 0.3s ease;
    }
</style>