<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdoMarket</title>
    
    <link rel="manifest" href="~/manifest.json" />
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LOGIN.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        /* Fondo Negro y Azul Marino para el cuerpo */
        body, html, main, .container, .container-fluid, [class*="bg-body"] {
            background-color: #050811 !important;
            background: radial-gradient(circle at top, #0a1128 0%, #050811 100%) !important;
            color: #ffffff !important;
        }

        h1, h2, h3, h4, h5, h6, .text-dark, .card-title, .card-text, .text-muted {
            color: #ffffff !important;
        }
        
        .text-muted {
            opacity: 0.6;
        }

        /* Tarjetas estilo Azul Marino Oscuro */
        .card, .producto-card, .force-white-card {
            background-color: #0b132b !important;
            border: 1px solid #1c2541 !important;
        }

        /* Hover con resplandor Azul Eléctrico Neón */
        .card:hover, .producto-card:hover, .force-white-card:hover {
            border-color: #00f0ff !important;
            box-shadow: 0 0 15px rgba(0, 240, 255, 0.4) !important;
        }

        /* Textos destacados e iconos en Azul Neón */
        .text-primary, .bi-shop, .fs-4, .product-price, .bi-box {
            color: #00f0ff !important;
        }

        .bg-light, .card-img-top {
            background-color: #0a1128 !important;
        }

        /* Botones estilo Azul Eléctrico / Neón */
        .btn-danger, .btn-gradient, .add-to-cart, .btn-primary, .btn-dark, .btn-info {
            background-color: #007bff !important;
            background-image: none !important;
            color: #ffffff !important;
            border: 1px solid #0056b3 !important;
            box-shadow: 0 4px 10px rgba(0, 123, 255, 0.3);
        }

        .btn-danger:hover, .btn-gradient:hover, .add-to-cart:hover, .btn-primary:hover, .btn-dark:hover, .btn-info:hover {
            background-color: #00f0ff !important;
            border-color: #00f0ff !important;
            color: #050811 !important;
            font-weight: bold;
            box-shadow: 0 0 12px #00f0ff;
        }

        .border-top, .border-bottom {
            border-color: #1c2541 !important;
        }

        /* Efecto hover para los enlaces del menú */
        .nav-link:hover {
            color: #00f0ff !important;
            text-shadow: 0 0 8px #00f0ff;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark mb-4 shadow-sm" style="background-color: #0b132b !important; border-bottom: 2px solid #00f0ff !important;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-2"></i>AdoMarket
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Productos" asp-action="Index">
                                    <i class="bi bi-grid-1x2 me-1 opacity-75"></i> Inventario
                                </a>
                            </li>
                            <li class="nav-item me-3">
                                <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Tienda" asp-action="Index">
                                    <i class="bi bi-cart3 me-1 opacity-75"></i> Ventas
                                </a>
                            </li>
                            <li class="nav-item me-3">
                                <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Reportes" asp-action="Index">
                                    <i class="bi bi-file-earmark-bar-graph me-1 opacity-75"></i> Reportes
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Tienda" asp-action="Index">
                                    <i class="bi bi-shop me-1 opacity-75"></i> Tienda
                                </a>
                            </li>
                            <li class="nav-item me-3">
                                <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Tienda" asp-action="MisCompras">
                                    <i class="bi bi-clock-history me-1 opacity-75"></i> Mis Pedidos
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center fw-bold" style="color: #ff4d5a !important;" asp-area="" asp-controller="Home" asp-action="Salir">
                                    <i class="bi bi-box-arrow-right me-1"></i> Salir
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center fw-bold text-info" asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Ingresar
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5" style="border-top: 1px solid #1c2541 !important; background-color: #050811 !important;">
        <div class="container text-center" style="color: #888888 !important;">
            &copy; 2026 - AdoMarket (Cochabamba) - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: #00f0ff !important; text-decoration: none;">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>