<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LOGIN.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body, html, main, .container, .container-fluid, [class*="bg-body"] {
            background-color: #000000 !important;
            background: #000000 !important;
            color: #ffffff !important;
        }

        h1, h2, h3, h4, h5, h6, .text-dark, .card-title, .card-text, .text-muted {
            color: #ffffff !important;
        }
        
        .text-muted {
            opacity: 0.7;
        }

        .card, .producto-card, .force-white-card {
            background-color: #121212 !important;
            background: #121212 !important;
            border: 1px solid #262626 !important;
        }

        .card:hover, .producto-card:hover, .force-white-card:hover {
            border-color: #dc3545 !important;
            box-shadow: 0 8px 20px rgba(220, 53, 69, 0.25) !important;
        }

        .text-primary, .bi-shop, .fs-4, .product-price {
            color: #ff4d5a !important;
        }

        .bg-light, .card-img-top {
            background-color: #1a1a1a !important;
            background: #1a1a1a !important;
        }

        .btn-danger, .btn-gradient, .add-to-cart, .btn-primary, .btn-dark {
            background-color: #dc3545 !important;
            background-image: none !important;
            color: #ffffff !important;
            border: 1px solid #dc3545 !important;
        }

        .btn-danger:hover, .btn-gradient:hover, .add-to-cart:hover, .btn-primary:hover, .btn-dark:hover {
            background-color: #b30006 !important;
            border-color: #b30006 !important;
            color: #ffffff !important;
        }

        .border-top, .border-bottom {
            border-color: #2d2d2d !important;
        }

        /* Efecto hover para los links de la barra de navegación */
        .nav-link:hover {
            color: #dc3545 !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark mb-4 shadow-sm" style="background-color: #121212 !important; border-bottom: 2px solid #dc3545 !important;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box me-2" style="color: #0dcaf0 !important;"></i>TechStore
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item me-3">
                            <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Productos" asp-action="Index">
                                <i class="bi bi-grid-1x2 me-1 opacity-75"></i> Inventario
                            </a>
                        </li>
                        <li class="nav-item me-3">
                            <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Tienda" asp-action="Index">
                                <i class="bi bi-shop me-1 opacity-75"></i> Tienda
                            </a>
                        </li>
                        <li class="nav-item me-3">
                            <a class="nav-link text-white d-flex align-items-center" asp-area="" asp-controller="Tienda" asp-action="MisCompras">
                                <i class="bi bi-bag-check me-1 opacity-75"></i> Mis Pedidos
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center fw-bold" style="color: #dc3545 !important;" asp-area="" asp-controller="Home" asp-action="Salir">
                                <i class="bi bi-box-arrow-right me-1"></i> Salir
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5" style="border-top: 1px solid #2d2d2d !important; background-color: #000000 !important;">
        <div class="container text-center" style="color: #888888 !important;">
            &copy; 2024 - TechStore - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: #dc3545 !important; text-decoration: none;">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>